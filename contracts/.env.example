# ─── contracts/.env.example ────────────────────────────────────────────
# Скопируй в .env и заполни:
#   cp .env.example .env

# 24-словная мнемоника кошелька-деплоера (Blueprint читает отсюда)
# Это тот же кошелёк, что потом будет подписывать выплаты (backend wallet)
MNEMONIC=bomb fold pistol cry display total human bind debate urge inch sing hammer rookie lady amateur indoor start casino record liar dentist sail bus

# TON-адрес для получения:
#   10% admin fee из Pool  (Pool.owner)
#   5%  marketplace fee из Escrow (Escrow.feeWallet)
# Если не задан — оба идут на адрес деплоера
ADMIN_WALLET=

# Эндпоинт (testnet по умолчанию)
TON_ENDPOINT=https://testnet.toncenter.com/api/v2/
